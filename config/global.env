# Configuration globale pour tous les conteneurs Docker
# Ce fichier est OPTIONNEL - chaque Makefile fonctionne sans
# Mais fournit des valeurs par défaut cohérentes
# definition de la structure des répertoires de travail


libs_root="${root_path}/lib"

# === LOGGING ===
LOG_LEVEL=info
LOG_FORMAT=json
SYSLOG_FACILITY=local0

# === DEVELOPMENT ===
DEV_MODE=false
DEBUG_MODE=false
TEST_MODE=false

# === CI/CD ===
AUTO_PUSH=false
AUTO_TEST=true
SCAN_IMAGE=true

# === TIMEOUTS ===
BUILD_TIMEOUT=1800
TEST_TIMEOUT=300
DEPLOY_TIMEOUT=600

# Variables calculées (ne pas modifier)
BUILD_DATE=$(date -u +%Y-%m-%dT%H:%M:%SZ)
BUILD_VERSION=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
BUILD_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
PARALLEL_BUILDS=4
BUILD_TIMEOUT=300
HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_TIMEOUT=10s
HEALTHCHECK_RETRIES=3


# Répertoires standards
LOGS_DIR=logs
TESTS_DIR=tests
SCRIPTS_DIR=scripts
RESOURCES_DIR=resources

# Options de sécurité
SECURITY_SCANNING=true
VULNERABILITY_THRESHOLD=medium
USER_NAMESPACE=true

# Debug et logging
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# Performance
MEMORY_LIMIT=2g
CPU_LIMIT=2
SWAP_LIMIT=1g

